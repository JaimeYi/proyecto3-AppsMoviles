<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:proyecto3.ViewModels"
             x:Class="proyecto3.Views.NuevaTransaccionPage"
             x:DataType="viewmodels:NuevaTransaccionViewModel"
             Title="Nueva Transacción"
             BackgroundColor="#F3F4F6">

    <ScrollView>
        <Grid RowDefinitions="180, *">
            <!-- Header Background (Dark Purple) -->
            <Grid Grid.Row="0" BackgroundColor="#2A114E" Padding="20">
                <VerticalStackLayout VerticalOptions="Center">
                    <Label Text="Nueva transacción" 
                           TextColor="White" 
                           FontSize="28" 
                           FontAttributes="Bold" />
                </VerticalStackLayout>
            </Grid>

            <!-- Main Form Card (Overlapping) -->
            <Border Grid.Row="1"
                    Margin="20,-40,20,20"
                    Padding="24"
                    BackgroundColor="White"
                    StrokeThickness="0"
                    StrokeShape="RoundRectangle 16">
                <Border.Shadow>
                    <Shadow Brush="#000000" Offset="0,4" Radius="10" Opacity="0.1" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="20">
                    <!-- Glosa Field -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Glosa" 
                               TextColor="#6B7280" 
                               FontSize="14" 
                               FontAttributes="Bold" />
                        <Border Stroke="#D1D5DB" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="12,0">
                            <Entry Text="{Binding Glosa}" 
                                   Placeholder="Ej. Supermercado o Sueldo" 
                                   TextColor="#111827" 
                                   FontSize="16"
                                   HeightRequest="44" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Cantidad Field -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Cantidad" 
                               TextColor="#6B7280" 
                               FontSize="14" 
                               FontAttributes="Bold" />
                        <Border Stroke="#D1D5DB" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="12,0">
                            <Entry Text="{Binding Cantidad}" 
                                   Placeholder="0" 
                                   Keyboard="Numeric" 
                                   TextColor="#111827" 
                                   FontSize="16"
                                   HeightRequest="44" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Fecha Field -->
                    <VerticalStackLayout Spacing="6">
                        <Label Text="Fecha" 
                               TextColor="#6B7280" 
                               FontSize="14" 
                               FontAttributes="Bold" />
                        <Border Stroke="#D1D5DB" StrokeThickness="1" StrokeShape="RoundRectangle 8" Padding="12,0">
                            <DatePicker Date="{Binding Fecha}" 
                                        Format="dd/MM/yyyy" 
                                        TextColor="#111827" 
                                        FontSize="16"
                                        HeightRequest="44" />
                        </Border>
                    </VerticalStackLayout>

                    <!-- Es Ingreso Checkbox -->
                    <HorizontalStackLayout Spacing="10" VerticalOptions="Center">
                        <CheckBox IsChecked="{Binding EsIngreso}" Color="#4F46E5" />
                        <Label Text="¿Es ingreso?" 
                               TextColor="#374151" 
                               FontSize="16" 
                               VerticalOptions="Center" />
                    </HorizontalStackLayout>

                    <!-- Action Buttons -->
                    <HorizontalStackLayout Spacing="12" Margin="0,10,0,0">
                        <Button Text="Guardar" 
                                Command="{Binding GuardarCommand}"
                                BackgroundColor="#4F46E5" 
                                TextColor="White" 
                                FontAttributes="Bold"
                                CornerRadius="8"
                                Padding="20,0"
                                HeightRequest="44" />
                        
                        <Button Text="Cancelar" 
                                Command="{Binding CancelarCommand}"
                                BackgroundColor="#8B0000" 
                                TextColor="White" 
                                FontAttributes="Bold"
                                CornerRadius="8"
                                Padding="20,0"
                                HeightRequest="44" />
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>
    </ScrollView>
</ContentPage>
